{
  "name": "quality-gate",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic quality gate for GitHub issues and pull requests so work lands well-scoped and actionable.",
  "author": "Orestes Carracedo <orestes@orestes.io>",
  "type": "module",
  "packageManager": "yarn@4.16.0",
  "bin": "bin/cli.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "^5",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,yml,yaml,json}": "prettier --write"
  }
}
