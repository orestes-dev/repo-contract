#!/usr/bin/env sh
# Repo-contract pre-commit hook, vendored by repo-contract `init` (ADR 0002,
# ADR 0012, orestes/dotfiles#52). A committed file, so it runs where ~/.dotfiles
# is absent (CI, containers, fresh worktrees). Depends only on POSIX sh, git, and
# jq (jq only when .repo-contract.json exists), never on node_modules, so it runs
# before `yarn install`.
#
# Activation is a separate matter from execution: git runs this file only while
# core.hooksPath points at .husky. `init` sets exactly that relative value, so a
# checkout that never installed anything is still covered and each linked worktree
# runs the hooks committed on its own branch. Git execs this file directly, with no
# husky shim, so it must stay executable; keep the body free of bashisms.
#
# repo-contract owns this file byte-for-byte and drift-checks it: edit
# templates/husky/pre-commit upstream and re-run `init`, never patch in place.
# Opt-outs live in the committed .repo-contract.json (never `git config hooks.*`).
# Repo-specific checks (lint-staged, gitleaks, build) go in .husky/local/pre-commit,
# chained below. They are tier-3 project checks and are not this hook's concern.
set -eu

CONFIG=".repo-contract.json"

red() { printf '\033[31m%s\033[0m\n' "$*" >&2; }
yellow() { printf '\033[33m%s\033[0m\n' "$*" >&2; }

# Populate OV_VALUE (the opt-out's JSON value) and OV_REASON from .repo-contract.json
# for the key named in $1. Returns 0 when the key is present, 1 otherwise. jq is
# required only when the config file exists.
OV_VALUE=""
OV_REASON=""
read_override() {
  OV_VALUE=""
  OV_REASON=""
  [ -f "$CONFIG" ] || return 1
  if ! command -v jq >/dev/null 2>&1; then
    red "pre-commit: $CONFIG exists but jq is not installed; cannot read opt-outs. Install jq."
    exit 1
  fi
  entry=$(jq -c --arg k "$1" '(.overrides // {})[$k] // empty' "$CONFIG") || {
    red "pre-commit: $CONFIG is not valid JSON."
    exit 1
  }
  [ -n "$entry" ] || return 1
  OV_VALUE=$(printf '%s' "$entry" | jq -c '.value')
  OV_REASON=$(printf '%s' "$entry" | jq -r '.reason')
  return 0
}

# Render a triggered opt-out, quoting its reason verbatim so the bypass is legible
# where it takes effect. Mirrors src/config.js formatOverride().
format_override() {
  printf '%s opt-out from %s (%s): %s' "$1" "$CONFIG" "$OV_VALUE" "$OV_REASON"
}

# 1. Never commit to the default branch.
branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
default=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || true)
[ -n "$default" ] || default=$(git config --get init.defaultBranch 2>/dev/null || echo main)
if [ -n "$branch" ] && [ "$branch" = "$default" ]; then
  if read_override allowDefaultBranchCommits && [ "$OV_VALUE" = "true" ]; then
    yellow "pre-commit: default-branch commit allowed. $(format_override allowDefaultBranchCommits)"
  else
    red "pre-commit: refusing to commit directly to default branch '$default'."
    red "  Branch first:  git switch -c <name>"
    red "  Opt out:       add overrides.allowDefaultBranchCommits {\"value\":true,\"reason\":...} to $CONFIG"
    exit 1
  fi
fi

# 2. No em dashes in staged *.md / *.mdx, up to an optional budget.
max_allowed=0
budget_note=""
if read_override maxAllowedEmDashes; then
  max_allowed=$OV_VALUE
  budget_note=$(format_override maxAllowedEmDashes)
fi
staged_md=$(git diff --cached --name-only --diff-filter=AM -z -- '*.md' '*.mdx' | tr '\0' '\n')
if [ -n "$staged_md" ]; then
  offending=$(git diff --cached --diff-filter=AM -- '*.md' '*.mdx' | grep -E '^\+[^+]' | grep -F '—' || true)
  if [ -n "$offending" ]; then
    count=$(printf '%s' "$offending" | grep -o '—' | wc -l | tr -d ' ')
    if [ "$count" -gt "$max_allowed" ]; then
      red "pre-commit: $count em-dash(es) in staged *.md/*.mdx (max allowed: $max_allowed). Use ',' '.' '()' ':' instead."
      printf '%s\n' "$offending" | head -10 >&2
      red "  Raise the budget: set overrides.maxAllowedEmDashes {\"value\":<n>,\"reason\":...} in $CONFIG"
      exit 1
    fi
    if [ -n "$budget_note" ]; then
      yellow "pre-commit: $count em-dash(es) within budget. $budget_note"
    fi
  fi
fi

# Chain to an optional consumer-owned extension for repo-specific checks.
# repo-contract never writes .husky/local/, so it survives `init --force`.
# Tier-3 checks do depend on node_modules (lint-staged, gitleaks), so put the
# project's binaries on PATH first, the way husky's shim used to.
PATH="node_modules/.bin:$PATH"
export PATH
if [ -r ".husky/local/pre-commit" ]; then
  sh -e ".husky/local/pre-commit" "$@"
fi

exit 0
